{
  "$meta": {
    "source": "Бренд-бук «Мастерская» v1.0 (экспорт, не править вручную в компонентах)",
    "note": "Источник истины для цвета и типографики. web/src/styles генерится отсюда."
  },
  "color": {
    "base": {
      "white":       { "hex": "#FFFFFF", "use": "фон, пространство" },
      "orange":      { "hex": "#E67E22", "use": "акцент, логотип, заливки — НЕ ТЕКСТ" },
      "orange-deep": { "hex": "#D35400", "use": "кнопки, ссылки, заголовки (крупно)" },
      "ink-soft":    { "hex": "#5C4033", "use": "текст, заголовки" },
      "ink":         { "hex": "#3E2A1A", "use": "основной текст (венге)" }
    },
    "wood": {
      "wood":        { "hex": "#8B5A2B", "use": "рамки, акценты, текст (AAA на светлом)" },
      "wood-dark":   { "hex": "#5C3E20" },
      "wood-darkest":{ "hex": "#2A1B10", "use": "тёмный фон" }
    },
    "interior": {
      "_note": "для соцсетей и атмосферы, НЕ для основной полиграфии/UI",
      "cream":  { "hex": "#F9F6F0" },
      "sand":   { "hex": "#D6C5A9" },
      "olive":  { "hex": "#6B705C" },
      "paper":  { "hex": "#F2ECE0" }
    },
    "state": {
      "_note": "только для интерфейсов (формы, статусы)",
      "success": { "hex": "#6B8E5A" },
      "warning": { "hex": "#C8851D" },
      "error":   { "hex": "#B0413A" },
      "info":    { "hex": "#5C7A8B" }
    },
    "orange-ramp": {
      "_note": "ховеры, рамки, состояния — производная от orange/orange-deep",
      "200": "#F2C79E",
      "400": "#EB9A4D",
      "500": "#E67E22",
      "600": "#D35400",
      "700": "#A8430C"
    }
  },
  "contrast_rules": {
    "_critical": "Нарушение = баг. brand-guardian обязан ловить.",
    "orange_is_not_text": "#E67E22 на белом = 2.85:1 (FAIL). Только заливки/знак/плашки.",
    "body_text_colors": ["#3E2A1A", "#5C4033", "#8B5A2B"],
    "body_text_note": "все три дают AAA на светлом фоне",
    "orange_deep_usage": "#D35400 на белом = 4.17:1 (AA крупный). Заголовки/кнопки, НЕ мелкий текст.",
    "button": "заливка #D35400 + белый текст, от 16px, полужирный"
  },
  "typography": {
    "fonts": {
      "headings": "Raleway",
      "overline_accent": "Montserrat",
      "body": "Open Sans",
      "fallback": "-apple-system, 'Segoe UI', Roboto, Arial, sans-serif",
      "license": "OFL, бесплатны коммерчески, кириллица, self-hosted (без Google CDN)"
    },
    "rules": {
      "max_fonts_per_material": 2,
      "no_small_caps": true,
      "no_script_italics": true,
      "accent": "Bold, не капитель",
      "logo_wordmark": "слово «МАСТЕРСКАЯ» — часть знака. Не перенабирать, брать файл логотипа."
    },
    "scale": {
      "display":  { "size": "3.0rem",      "line": 1.1,  "font": "Raleway", "weight": 200 },
      "h1":       { "size": "2.4rem",      "line": 1.12, "font": "Raleway", "weight": 600 },
      "h2":       { "size": "1.8rem",      "line": 1.18, "font": "Raleway", "weight": 600 },
      "h3":       { "size": "1.18rem",     "line": 1.3,  "font": "Raleway", "weight": 600 },
      "overline": { "size": "0.72rem",     "line": 1.4,  "font": "Montserrat", "weight": 600, "letter_spacing": "0.24em" },
      "lead":     { "size": "1.3rem",      "line": 1.6,  "font": "Raleway", "weight": 300 },
      "body":     { "size": "1.0rem",      "line": 1.75, "font": "Open Sans", "weight": 400 },
      "small":    { "size": "0.72-0.85rem","line": 1.5,  "font": "Open Sans", "weight": 400 }
    }
  },
  "logo": {
    "mark": "раскидистое дерево в круге",
    "min_size": { "screen": "24px", "print": "12mm" },
    "clear_space": "не меньше высоты ствола со всех сторон",
    "donts": [
      "менять фирменный оранжевый",
      "растягивать/сжимать/искажать",
      "тени, обводки, градиенты",
      "пёстрый фон без контраста",
      "поворачивать знак / наклонять надпись",
      "пересобирать дерево и надпись по-своему"
    ]
  },
  "imagery": {
    "_note": "правила съёмки (см. бренд-бук §09) — brand-guardian проверяет даже плейсхолдеры",
    "light": "дневной или тёплый искусственный, без резких теней и тяжёлых фильтров",
    "subjects": ["дерево", "чай (пар над чашкой)", "руки", "книги", "люди, которым здесь хорошо"],
    "avoid": ["тяжёлые фильтры", "кислотные цвета", "пересвет", "постановочный сток"],
    "formats": { "post": "1080×1080 / 1080×1350", "stories": "1080×1920" }
  }
}
