# Шаблон окружения. Скопировать в .env (он в .gitignore) и заполнить ЧЕЛОВЕКОМ.
# Агенты .env НЕ создают и пароли НЕ задают (см. CLAUDE.md §2).

# Админка (одна роль). Пароль/секрет задаёт человек, не коммитится.
ADMIN_USER=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

# БД
DATABASE_URL=file:./api/db/masterskaya.db

# Яндекс.Метрика
METRIKA_COUNTER_ID=91052806
