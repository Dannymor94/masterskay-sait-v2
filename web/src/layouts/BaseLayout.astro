---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
}

const DEFAULT_TITLE = '«Мастерская» — центр практик в Ростове-на-Дону';
const DEFAULT_DESCRIPTION =
  'Центр практик Мастерская в Ростове-на-Дону. Аренда залов, расписание занятий, события. Фурмановская 79/41.';

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
} = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Мастерская',
  url: 'https://yoga-rostov-mst.ru',
  telephone: '+7-938-100-57-57',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Фурмановская 79/41',
    addressLocality: 'Ростов-на-Дону',
    addressRegion: 'Ростовская область',
    addressCountry: 'RU',
  },
  openingHours: 'Mo-Su 07:00-22:00',
  priceRange: '₽₽',
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <!-- OG / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Мастерская" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://yoga-rostov-mst.ru/og-default.svg" />
    <meta property="og:url" content={`https://yoga-rostov-mst.ru${Astro.url.pathname}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://yoga-rostov-mst.ru/og-default.svg" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    {/* Предзагрузка ключевых шрифтов выше сгиба (Raleway 200/600, Open Sans 400) */}
    <link rel="preload" href="/fonts/Raleway-SemiBold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/OpenSans-Regular.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <a class="visually-hidden" href="#main">К основному содержимому</a>
    <slot name="header" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
    <CookieBanner />
  </body>
</html>
