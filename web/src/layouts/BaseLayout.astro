---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Центр практик «Мастерская», Ростов-на-Дону' } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {/* Предзагрузка ключевых шрифтов выше сгиба (Raleway 200/600, Open Sans 400) */}
    <link rel="preload" href="/fonts/Raleway-SemiBold.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/OpenSans-Regular.ttf" as="font" type="font/ttf" crossorigin />
  </head>
  <body>
    <a class="visually-hidden" href="#main">К основному содержимому</a>
    <slot name="header" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
