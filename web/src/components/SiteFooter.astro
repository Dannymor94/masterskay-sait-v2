---
/**
 * SiteFooter.astro — подвал сайта. Тёмный венге-фон (var(--color-wood-darkest)),
 * на нём белый/светлый текст (AA). Оранжевый — только как заливка знака.
 * Контакты/адрес — заглушки (TODO: реальные данные от Даниила).
 */
const year = new Date().getFullYear();
const nav = [
  { label: 'Аренда', href: '/arenda' },
  { label: 'Расписание', href: '/raspisanie' },
  { label: 'Направления', href: '/napravleniya' },
  { label: 'Практики', href: '/praktiki' },
  { label: 'Чайная', href: '/chaynaya' },
  { label: 'Контакты', href: '/kontakty' },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      {/* TODO LOGO: заменить на светлую версию готового логотипа. */}
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__word">Мастерская</span>
      <p class="site-footer__tagline">
        Центр практик в Ростове-на-Дону.<br />
        Тёплое пространство для регулярной работы.
      </p>
    </div>

    <nav class="site-footer__nav" aria-label="Навигация в подвале">
      <h2 class="site-footer__heading">Разделы</h2>
      <ul>
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="site-footer__contacts">
      <h2 class="site-footer__heading">Контакты</h2>
      {/* TODO: реальные контакты (адрес, телефон, мессенджеры) от Даниила. */}
      <address class="site-footer__address">
        Ростов-на-Дону<br />
        Адрес уточняется<br />
        <a href="/kontakty">Связаться с нами</a>
      </address>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container site-footer__bottom-inner">
      <p>© {year} «Мастерская»</p>
      <p><a href="/privacy">Политика конфиденциальности</a></p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-wood-darkest);
    color: color-mix(in srgb, var(--color-white) 86%, var(--color-sand));
    margin-top: var(--space-6);
  }
  .site-footer__inner {
    display: grid;
    gap: var(--space-4);
    padding-block: var(--space-5) var(--space-4);
  }

  .brand__mark {
    display: inline-block;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--accent-fill);
    vertical-align: middle;
  }
  .brand__word {
    font-family: var(--font-headings);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--color-white);
    margin-left: 0.5rem;
    vertical-align: middle;
  }
  .site-footer__tagline {
    margin-top: var(--space-2);
    font-size: 0.95rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-white) 78%, var(--color-sand));
    max-width: 34ch;
  }

  .site-footer__heading {
    font-family: var(--font-overline);
    font-size: var(--text-overline);
    font-weight: 600;
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--color-sand);
    margin: 0 0 var(--space-2);
  }
  .site-footer__nav ul,
  .site-footer__address {
    list-style: none;
    margin: 0;
    padding: 0;
    font-style: normal;
    line-height: 1.9;
  }
  .site-footer a {
    color: color-mix(in srgb, var(--color-white) 90%, var(--color-sand));
    text-decoration: none;
  }
  .site-footer a:hover {
    color: var(--color-white);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .site-footer__bottom {
    border-top: 1px solid color-mix(in srgb, var(--color-white) 14%, transparent);
  }
  .site-footer__bottom-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: space-between;
    padding-block: var(--space-2);
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-white) 70%, var(--color-sand));
  }
  .site-footer__bottom-inner p {
    margin: 0;
  }

  @media (min-width: 48rem) {
    .site-footer__inner {
      grid-template-columns: 1.6fr 1fr 1fr;
      gap: var(--space-5);
    }
  }
</style>
