---
/**
 * HallCard.astro — карточка зала (#zaly). Фото-первым (A1: специалист решает по
 * фото своего будущего кабинета), бейджи-метрики, описание-настроение, чек-лист
 * оснащения, подпись под ставку (O2 — заглушка «по запросу»), контекстный CTA
 * «Хочу вести здесь» с предзаполнением зала через query-параметр.
 *
 * cta_origin/предзаполнение зала: ссылка ведёт на #zayavka с ?hall=<slug>.
 * frontend (T0-6) на основе этого предвыберет зал в форме. Бейджи и оснащение —
 * данные-пропсы, чтобы реальные значения (TODO O2 / оснащение) подставлялись
 * без переверстки.
 *
 * Палитра: бейджи — контур var(--border) + текст венге var(--text) (AA/AAA на
 * белом); оранжевый — только маркер-точка перед текстом (знак-заливка, НЕ текст).
 * Маркеры списка оснащения — orange-fill (знак-заливка). CTA — secondary.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Button from './Button.astro';

interface Props {
  name: string;
  badges: string[];
  description: string;
  equipment: string[];
  rateNote: string;
  image: ImageMetadata; // импортированный плейсхолдер (оптимизирует Astro <Image>)
  imageAlt: string;
  photoSlot: string; // data-photo-slot маркер для замены на реальное фото одним файлом
  hallValue: string; // значение для предзаполнения формы (?hall=...)
}
const {
  name,
  badges,
  description,
  equipment,
  rateNote,
  image,
  imageAlt,
  photoSlot,
  hallValue,
} = Astro.props;

// Ссылка ведёт к форме с предзаполнением зала: query ДО хеша, чтобы это был
// настоящий ?hall=, который читается и на сервере (M1), и в JS (frontend T0-6).
const ctaHref = `/arenda?hall=${encodeURIComponent(hallValue)}#zayavka`;
---

<article class="hall">
  <figure class="hall__media">
    {/* Ниже сгиба → lazy. Оптимизация Astro <Image> (sharp), кадр 4:3 (1200×900). */}
    <Image
      src={image}
      width={1200}
      height={900}
      alt={imageAlt}
      widths={[320, 480, 640]}
      sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
      loading="lazy"
      decoding="async"
      data-photo-slot={photoSlot}
    />
  </figure>

  <div class="hall__body">
    <h3 class="hall__name">{name}</h3>

    <ul class="hall__badges" aria-label="Параметры зала">
      {badges.map((b) => <li class="hall__badge">{b}</li>)}
    </ul>

    <p class="hall__desc">{description}</p>

    <h4 class="hall__sub">Оснащение</h4>
    <ul class="hall__equip">
      {equipment.map((item) => <li>{item}</li>)}
    </ul>

    <div class="hall__footer">
      {/* TODO O2: заменить текст-заглушку на реальную ставку (месяц/абонемент). */}
      <p class="hall__rate">{rateNote}</p>
      <Button variant="secondary" href={ctaHref}>Хочу вести здесь</Button>
    </div>
  </div>
</article>

<style>
  .hall {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 1px solid color-mix(in srgb, var(--border) 22%, transparent);
    border-radius: var(--radius-lg);
    overflow: hidden;
    height: 100%;
  }

  .hall__media {
    margin: 0;
    background: var(--surface);
  }
  .hall__media img {
    width: 100%;
    aspect-ratio: 4 / 3; /* 1200×900 */
    object-fit: cover;
  }

  .hall__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3);
    flex: 1 1 auto;
  }
  .hall__name {
    margin: 0;
  }

  .hall__badges {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }
  .hall__badge {
    /* Контурный бейдж: текст венге var(--text) (AAA на белом), рамка var(--border).
       Оранжевый НЕ как мелкий текст — только маркер-точка перед текстом (знак-
       заливка). Так бейдж проходит контраст AA на белом фоне. */
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--bg);
    color: var(--text);
    border: 1px solid color-mix(in srgb, var(--border) 45%, transparent);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.3;
    padding: 0.22rem 0.65rem;
    border-radius: 999px;
  }
  .hall__badge::before {
    /* Оранжевый маркер-точка (знак-заливка, не текст). */
    content: '';
    flex: 0 0 auto;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--accent-fill);
  }

  .hall__desc {
    margin: 0;
    color: var(--text);
    font-size: 0.98rem;
    flex: 1 1 auto; /* поглощает разницу в длине текстов, прибивая footer вниз */
  }

  .hall__sub {
    font-family: var(--font-overline);
    font-size: var(--text-overline);
    font-weight: 600;
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--text-muted);
    margin: var(--space-1) 0 0;
  }
  .hall__equip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }
  .hall__equip li {
    position: relative;
    padding-left: 1.4rem;
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.5;
  }
  .hall__equip li::before {
    /* Маркер — заливка orange-fill (знак, не текст). */
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--accent-fill);
  }

  .hall__footer {
    margin-top: auto;
    padding-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-top: 1px solid color-mix(in srgb, var(--border) 18%, transparent);
  }
  .hall__rate {
    margin: 0;
    font-size: 0.92rem;
    color: var(--text-muted);
  }
</style>
