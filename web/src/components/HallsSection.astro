---
/**
 * HallsSection.astro — секция «Три зала» (#zaly). Заголовок + подзаголовок +
 * сетка карточек (1 кол. мобайл → 2 → 3 на десктопе). Данные залов — массив,
 * чтобы реальные оснащение/ставки (TODO O2) подставлялись точечно.
 *
 * Тексты — дословно из web/src/content/arenda.md (секция zaly).
 */
import HallCard from './HallCard.astro';
// Плейсхолдеры импортируем из src/assets → Astro оптимизирует их через <Image>.
import hallBigImg from '../assets/placeholders/hall-big.jpg';
import hallSmallImg from '../assets/placeholders/hall-small.jpg';
import hallTeaImg from '../assets/placeholders/hall-tea.jpg';
import { listHalls } from '../server/halls.ts';

// Получаем реальные фото из БД; компонент встраивается в SSR-страницу, поэтому
// серверный импорт работает без client:* директив.
const dbHalls = listHalls();
const hallPhotoMap = new Map(dbHalls.map((h) => [h.id, h.photo_url]));

const halls = [
  {
    name: 'Большой зал',
    badges: ['70 м²', 'до 15 человек'], // TODO уточнить вместимость
    description:
      'Просторный зал для групп и активной работы. Высокий потолок, много воздуха, дневной свет вдоль стены. Здесь хватит места на коврики по кругу и на то, чтобы двигаться свободно.',
    equipment: [
      'Тёплый пол из дерева', // TODO уточнить покрытие пола
      'Дневной свет и регулируемое мягкое освещение',
      'Коврики и реквизит для групповых практик', // TODO уточнить инвентарь
      'Чайная зона рядом — можно остаться после занятия',
    ],
    rateNote: 'от 700 ₽/час · регулярная по договорённости', // TODO O2: заменить на реальную ставку из /admin
    image: hallBigImg,
    imageAlt: 'Деревянный пол, высокие потолки, дневной свет вдоль стены — просторный зал для групп',
    photoSlot: 'hall-big',
    hallValue: 'big-70',
  },
  {
    name: 'Малый зал',
    badges: ['30 м²', 'для камерной работы'],
    description:
      'Спокойный зал для индивидуальной работы и небольших групп. Подходит для массажа, консультации, телесной практики один на один. Здесь тихо и приватно — клиент чувствует, что пришёл в безопасное место.',
    equipment: [
      'Тёплый пол, мягкое освещение', // TODO уточнить покрытие пола
      'Место под кушетку или кресло', // TODO уточнить: предоставляется ли мебель
      'Уединение: зал в стороне от общего потока',
      'Чайная зона рядом',
    ],
    rateNote: 'от 350 ₽/час · регулярная по договорённости', // TODO O2: заменить на реальную ставку из /admin
    image: hallSmallImg,
    imageAlt: 'Тихое камерное пространство — тёплый свет, уединение, место для работы один на один',
    photoSlot: 'hall-small',
    hallValue: 'small-30',
  },
  {
    name: 'Чайный зал',
    badges: ['45 м²', 'круг и чай'],
    description:
      'Зал с чайной зоной — для встреч, медитаций и неспешных форматов. Здесь хорошо сидеть в кругу, говорить и пить чай. То самое место, где практика естественно переходит в живое общение.',
    equipment: [
      'Чайная зона и низкая посадка', // TODO уточнить оснащение чайной
      'Тёплый свет, дерево, живые детали',
      'Место под круг или небольшую группу',
      'Посуда и чай для церемоний', // TODO уточнить: что входит
    ],
    rateNote: 'от 500 ₽/час · регулярная по договорённости', // TODO O2: заменить на реальную ставку из /admin
    image: hallTeaImg,
    imageAlt: 'Чайная зона с низкой посадкой, деревянные детали, тёплый рассеянный свет — зал для круга и медитаций',
    photoSlot: 'hall-tea',
    hallValue: 'tea-45',
  },
];
---

<section id="zaly" class="halls" aria-labelledby="halls-title">
  <div class="container">
    <header class="halls__head">
      <p class="overline">Залы</p>
      <h2 id="halls-title">Три зала</h2>
      <p class="lead">
        Выберите тот, в котором вашей практике будет на своём месте.
      </p>
    </header>

    <div class="halls__grid">
      {halls.map((hall) => (
        <HallCard {...hall} photoUrl={hallPhotoMap.get(hall.hallValue) ?? null} />
      ))}
    </div>
  </div>
</section>

<style>
  .halls {
    padding-block: var(--space-5);
  }
  .halls__head {
    max-width: 52ch;
    margin-bottom: var(--space-4);
  }
  .halls__head h2 {
    margin-bottom: var(--space-2);
  }
  .halls__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    align-items: stretch; /* карточки в одной строке всегда одинаковой высоты */
  }

  @media (min-width: 40rem) {
    .halls__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 64rem) {
    .halls__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
