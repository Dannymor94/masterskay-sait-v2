---
/**
 * AvailabilityPlaceholder.astro — «Свободные слоты» (#dostupnost).
 * Данных O2 (реальная занятость) НЕТ → компактный текстовый плейсхолдер:
 * два абзаца + ghost-кнопка к форме. Без таблиц, без точек, без пустых сеток.
 *
 * Когда появятся данные O2 — заменить этот компонент на полноценную сетку
 * занятости (дни × время суток, статусы свободно/занято).
 *
 * Тексты — дословно из arenda.md (секция dostupnost).
 */
import Button from './Button.astro';
---

<section id="dostupnost" class="avail" aria-labelledby="avail-title">
  <div class="container">
    <div class="avail__card">
      <p class="overline">Доступность</p>
      <h2 id="avail-title" class="avail__title">Свободные слоты</h2>
      <p class="avail__text">
        Свободные регулярные окна мы подбираем под вас — укажите в заявке
        удобные дни и время, посмотрим что есть и предложим вариант.
        Слотов конечное число, поэтому удобные вечера разбирают заранее.
      </p>
      <p class="avail__action">
        <Button variant="secondary" href="#zayavka">Написать о слоте</Button>
      </p>
    </div>
  </div>
</section>

<style>
  .avail {
    padding-block: var(--space-5);
  }

  .avail__card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-4);
    max-width: 56ch;
  }

  .avail__title {
    margin-top: var(--space-1);
    margin-bottom: var(--space-2);
  }

  .avail__text {
    margin: 0;
    color: var(--text-muted);
    line-height: var(--leading-body);
  }

  .avail__action {
    margin: var(--space-3) 0 0;
  }

  @media (min-width: 40rem) {
    .avail__card {
      padding: var(--space-4) var(--space-5);
    }
  }
</style>
