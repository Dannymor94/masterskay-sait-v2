---
/**
 * Metrika.astro — единая точка подключения Яндекс.Метрики (счётчик 91052806).
 *
 * Зачем компонент, а не сниппет на каждой странице: чтобы загрузку Метрики было
 * легко обернуть в согласие на куки позже (152-ФЗ). Подключаем точечно — только
 * на лендинге /arenda и странице /arenda/spasibo (M1), не на всех страницах.
 *
 * ⚠️ 152-ФЗ / приватность: Метрика ставит куки. В M1 счётчик и цель ставятся БЕЗ
 * баннера согласия. Баннер согласия на куки и наполнение /privacy — ДОЛГ
 * (SPEC §7, milestone M3) ИЛИ решение Антона. Когда баннер появится — здесь
 * добавляется проверка согласия перед инициализацией (props enabled / условие).
 *
 * Цель `reachGoal('arenda_lead')` вызывается на /arenda/spasibo через проп goal.
 */
interface Props {
  /** Если передан — после инициализации счётчика дёрнуть reachGoal(goal). */
  goal?: string;
}
const { goal } = Astro.props;
const COUNTER_ID = 91052806;
---

{/* Стандартный async-сниппет Яндекс.Метрики. is:inline — чтобы Astro не трогал
    глобальный инициализатор ym(). */}
<script is:inline define:vars={{ COUNTER_ID, goal }}>
  (function (m, e, t, r, i, k, a) {
    m[i] =
      m[i] ||
      function () {
        (m[i].a = m[i].a || []).push(arguments);
      };
    m[i].l = 1 * new Date();
    for (var j = 0; j < document.scripts.length; j++) {
      if (document.scripts[j].src === r) {
        return;
      }
    }
    (k = e.createElement(t)),
      (a = e.getElementsByTagName(t)[0]),
      (k.async = 1),
      (k.src = r),
      a.parentNode.insertBefore(k, a);
  })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js', 'ym');

  ym(COUNTER_ID, 'init', {
    clickmap: true,
    trackLinks: true,
    accurateTrackBounce: true,
  });

  // Цель конверсии (на /arenda/spasibo): вызываем ПОСЛЕ init.
  if (goal) {
    ym(COUNTER_ID, 'reachGoal', goal);
  }
</script>

<noscript>
  <div>
    <img
      src={`https://mc.yandex.ru/watch/${COUNTER_ID}`}
      style="position:absolute; left:-9999px;"
      alt=""
    />
  </div>
</noscript>
</content>
