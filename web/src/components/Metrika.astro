---
/**
 * Metrika.astro — единая точка подключения Яндекс.Метрики (счётчик 91052806).
 *
 * С T3-3 Метрика НЕ загружается отсюда напрямую — только через CookieBanner
 * после явного согласия пользователя (152-ФЗ). Этот компонент:
 * 1. Ставит noscript-пиксель (не устанавливает куки, только учёт без JS).
 * 2. Если передан prop `goal` — вызывает reachGoal ПОСЛЕ того, как window.ym
 *    станет доступен (на /arenda/spasibo, если пользователь дал согласие ранее).
 *
 * Загрузку самого счётчика выполняет CookieBanner.astro при нажатии «Принять».
 */
interface Props {
  /** Если передан — после инициализации счётчика дёрнуть reachGoal(goal). */
  goal?: string;
}
const { goal } = Astro.props;
const COUNTER_ID = 91052806;
---

{goal && (
  <script is:inline define:vars={{ COUNTER_ID, goal }}>
    // Вызываем цель только если Метрика уже загружена (пользователь дал согласие).
    // Ждём до 3 секунд на случай если загрузка ещё в процессе.
    (function tryGoal(attempts) {
      if (typeof window.ym === 'function') {
        window.ym(COUNTER_ID, 'reachGoal', goal);
      } else if (attempts > 0) {
        setTimeout(function () { tryGoal(attempts - 1); }, 300);
      }
    })(10);
  </script>
)}

<noscript>
  <div>
    <img
      src={`https://mc.yandex.ru/watch/${COUNTER_ID}`}
      style="position:absolute; left:-9999px;"
      alt=""
    />
  </div>
</noscript>
