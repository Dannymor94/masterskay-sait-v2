---
/**
 * 404.astro — brand-styled "not found" page.
 * Astro serves this automatically for unmatched routes.
 * Static: no SSR needed.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

export const prerender = true;
---

<BaseLayout title="Страница не найдена — «Мастерская»">
  <section class="error-page container">
    <p class="overline">Ошибка 404</p>
    <h1 class="error-page__title">Страница не найдена</h1>
    <p class="error-page__text">
      Такой страницы нет — возможно, адрес изменился или вы перешли по старой ссылке.
    </p>
    <div class="error-page__actions">
      <Button variant="primary" href="/">На главную</Button>
      <Button variant="secondary" href="/arenda">Аренда залов</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .error-page {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-block: var(--space-6);
    gap: var(--space-2);
  }

  .error-page__title {
    font-family: var(--font-headings);
    font-size: var(--text-h1);
    font-weight: var(--weight-h1);
    color: var(--heading);
    margin: 0;
  }

  .error-page__text {
    color: var(--text-muted);
    font-size: var(--text-lead);
    line-height: var(--leading-lead);
    max-width: 52ch;
    margin: 0;
  }

  .error-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }
</style>
