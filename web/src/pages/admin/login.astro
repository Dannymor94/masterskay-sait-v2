---
/**
 * /admin/login — форма входа (нативный POST, без JS). Одна роль.
 *
 * Если авторизация не настроена (нет env) — показываем понятную инструкцию для
 * Даниила, как завести секрет (НЕ 500, публичный сайт работает).
 * Иначе — форма логина: сверка с ADMIN_PASSWORD_HASH (scrypt), выдача подписанной
 * httpOnly-cookie на SESSION_SECRET.
 */
export const prerender = false;

import '../../styles/tokens.css';
import {
  isAuthConfigured,
  checkCredentials,
  issueSession,
  getAdminUser,
  SESSION_COOKIE,
  SESSION_COOKIE_OPTS,
} from '../../server/auth.ts';

const configured = isAuthConfigured();
let error = '';

if (Astro.request.method === 'POST' && configured) {
  const form = await Astro.request.formData();
  const user = String(form.get('user') ?? '').trim();
  const password = String(form.get('password') ?? '');
  if (checkCredentials(user, password)) {
    Astro.cookies.set(SESSION_COOKIE, issueSession(user), SESSION_COOKIE_OPTS);
    return Astro.redirect('/admin', 303);
  }
  error = 'Неверный логин или пароль.';
}
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Вход · Мастерская</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }

      body {
        font-family: var(--font-body);
        color: var(--text);
        background: var(--color-wood-darkest);
        display: grid;
        place-items: center;
        min-height: 100vh;
        margin: 0;
        padding: var(--space-3);
      }

      .login-wrap {
        width: 100%;
        max-width: 26rem;
      }

      .login-brand {
        text-align: center;
        margin-bottom: var(--space-3);
      }

      .login-brand__name {
        font-family: var(--font-headings);
        font-size: var(--text-h2);
        font-weight: var(--weight-h2);
        color: var(--color-orange-400);
        margin: 0 0 0.25rem;
        line-height: 1.1;
      }

      .login-brand__sub {
        font-size: 0.75rem;
        color: var(--color-sand);
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .login-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: var(--space-4) var(--space-3);
        box-shadow: 0 8px 32px color-mix(in srgb, var(--color-ink) 30%, transparent);
      }

      .login-card__title {
        font-family: var(--font-headings);
        font-size: var(--text-h3);
        font-weight: var(--weight-h3);
        color: var(--heading);
        margin: 0 0 var(--space-3);
      }

      .field {
        margin-bottom: var(--space-2);
      }

      .field label {
        display: block;
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 0.35rem;
        color: var(--text);
      }

      .field input {
        display: block;
        width: 100%;
        padding: 0.6rem 0.75rem;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font: inherit;
        font-size: 0.95rem;
        color: var(--text);
        background: var(--bg);
        transition: border-color 0.12s, box-shadow 0.12s;
      }

      .field input:focus {
        outline: none;
        border-color: var(--accent-fill);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-fill) 20%, transparent);
      }

      .btn-submit {
        display: block;
        width: 100%;
        margin-top: var(--space-2);
        padding: 0.65rem 1rem;
        background: var(--btn-bg);
        color: var(--btn-text);
        border: 0;
        border-radius: var(--radius-sm);
        cursor: pointer;
        font: inherit;
        font-size: 0.95rem;
        font-weight: 600;
        text-align: center;
        transition: background 0.12s, transform 0.08s;
      }

      .btn-submit:hover {
        background: var(--btn-bg-hover);
      }

      .btn-submit:active {
        transform: translateY(1px);
      }

      .login-error {
        margin-top: var(--space-2);
        padding: 0.6rem 0.75rem;
        background: color-mix(in srgb, var(--state-error) 10%, transparent);
        border: 1px solid color-mix(in srgb, var(--state-error) 30%, transparent);
        border-radius: var(--radius-sm);
        color: var(--state-error);
        font-size: 0.88rem;
        font-weight: 500;
      }

      /* === Setup instructions block === */
      .setup-notice {
        padding: var(--space-2);
        background: color-mix(in srgb, var(--state-info) 10%, transparent);
        border: 1px solid color-mix(in srgb, var(--state-info) 30%, transparent);
        border-radius: var(--radius-md);
        margin-bottom: var(--space-2);
      }

      .setup-notice strong {
        color: var(--state-info);
      }

      .setup-notice ol {
        margin: var(--space-1) 0 var(--space-1) 1.2rem;
        padding: 0;
        font-size: 0.88rem;
        line-height: 1.8;
      }

      code {
        font-size: 0.82rem;
        background: var(--surface);
        padding: 0.1rem 0.4rem;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        white-space: nowrap;
      }

      pre {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 0.75rem;
        overflow-x: auto;
        font-size: 0.8rem;
        line-height: 1.6;
        margin: var(--space-1) 0;
      }

      .muted {
        color: var(--text-muted);
        font-size: 0.82rem;
        margin-top: var(--space-1);
      }
    </style>
  </head>
  <body>
    <div class="login-wrap">
      <div class="login-brand" aria-hidden="true">
        <p class="login-brand__name">Мастерская</p>
        <span class="login-brand__sub">Панель управления</span>
      </div>

      <div class="login-card">
        {configured ? (
          <>
            <h1 class="login-card__title">Вход</h1>
            <form method="POST" action="/admin/login">
              <div class="field">
                <label for="user">Логин</label>
                <input
                  id="user"
                  name="user"
                  type="text"
                  autocomplete="username"
                  value={getAdminUser()}
                  required
                />
              </div>
              <div class="field">
                <label for="password">Пароль</label>
                <input
                  id="password"
                  name="password"
                  type="password"
                  autocomplete="current-password"
                  required
                />
              </div>
              {error && (
                <p class="login-error" role="alert">{error}</p>
              )}
              <button class="btn-submit" type="submit">Войти</button>
            </form>
          </>
        ) : (
          <>
            <h1 class="login-card__title">Доступ не настроен</h1>
            <div class="setup-notice">
              <strong>Это делает человек (не агент).</strong> Следуйте шагам ниже,
              чтобы включить вход в панель управления.
            </div>
            <ol>
              <li>
                Сгенерируйте хэш пароля:<br />
                <code>node scripts/hash-password.mjs 'ваш-пароль'</code>
              </li>
              <li>
                Сгенерируйте секрет сессии:<br />
                <code>openssl rand -hex 32</code>
              </li>
              <li>Положите в <code>web/.env</code> (не коммитить):</li>
            </ol>
            <pre>ADMIN_USER=admin
ADMIN_PASSWORD_HASH=scrypt$...
SESSION_SECRET=&lt;hex-строка&gt;</pre>
            <p class="muted">После перезапуска dev-сервера здесь появится форма входа.</p>
          </>
        )}
      </div>
    </div>
  </body>
</html>
