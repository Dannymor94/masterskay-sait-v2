---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { listHalls, createHall, removeHall, validateHall } from '../../server/halls.ts';

let error = '';
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('_action') ?? 'save');
  if (action === 'delete') {
    removeHall(String(form.get('id') ?? ''));
    return Astro.redirect('/admin/halls', 303);
  }
  const num = (k: string) => {
    const v = String(form.get(k) ?? '').trim();
    return v === '' ? null : Number(v);
  };
  const photo_url = String(form.get('photo_url') ?? '').trim() || null;
  const input = {
    id: String(form.get('id') ?? '').trim(),
    name: String(form.get('name') ?? '').trim(),
    area_m2: num('area_m2'),
    capacity: num('capacity'),
    equipment: String(form.get('equipment') ?? '').split(',').map((s) => s.trim()).filter(Boolean),
    rate_subscription: String(form.get('rate_subscription') ?? '').trim() || null,
    description: String(form.get('description') ?? '').trim() || null,
    photos: photo_url ? [photo_url] : [],
  };
  const v = validateHall(input);
  if (!v.ok) {
    error = Object.values(v.errors).join(' ');
  } else {
    createHall(input);
    return Astro.redirect('/admin/halls', 303);
  }
}
const halls = listHalls();
const user = Astro.locals.adminUser;
---
<AdminLayout title="Залы" user={user}>
  {error && <p class="err" role="alert">{error}</p>}
  <table>
    <thead><tr><th>id</th><th>Название</th><th>м²</th><th>Вмест.</th><th>Оснащение</th><th>Фото</th><th></th></tr></thead>
    <tbody>
      {halls.map((h) => (
        <tr>
          <td>{h.id}</td><td>{h.name}</td><td>{h.area_m2}</td><td>{h.capacity}</td>
          <td>{h.equipment.join(', ')}</td>
          <td>{h.photos.length > 0 ? <img src={h.photos[0]} alt="" style="max-height:40px;border-radius:var(--radius-sm)" /> : '—'}</td>
          <td>
            <form method="POST" class="inline">
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="id" value={h.id} />
              <button class="btn btn-secondary" type="submit">Удалить</button>
            </form>
          </td>
        </tr>
      ))}
    </tbody>
  </table>

  <div class="form-section">
  <h3>Создать / обновить зал</h3>
  <form method="POST">
    <label for="id">id (slug)</label><input id="id" name="id" required />
    <label for="name">Название</label><input id="name" name="name" required />
    <label for="area_m2">Площадь, м²</label><input id="area_m2" name="area_m2" type="number" />
    <label for="capacity">Вместимость</label><input id="capacity" name="capacity" type="number" />
    <label for="equipment">Оснащение (через запятую)</label><input id="equipment" name="equipment" />
    <label for="rate_subscription">Ставка (абонемент)</label><input id="rate_subscription" name="rate_subscription" value="по запросу" />
    <label for="description">Описание</label><textarea id="description" name="description" rows="2"></textarea>

    <label>Фото</label>
    <div class="photo-upload" id="photo-upload-hall">
      <noscript><p class="muted">Загрузка фото требует JavaScript.</p></noscript>
      <div class="photo-upload__ui">
        <div class="photo-upload__preview" id="hall-photo-preview" style="display:none">
          <img id="hall-photo-img" src="" alt="Превью фото" style="max-width:200px;border-radius:var(--radius-md)" />
        </div>
        <div style="display:flex;gap:var(--space-1);align-items:center;margin-top:var(--space-1)">
          <input type="file" id="hall-file-input" accept=".jpg,.jpeg,.png,.webp" style="font-size:0.85rem" />
          <button type="button" class="btn btn-secondary btn-sm" id="hall-upload-btn">Загрузить</button>
        </div>
        <p id="hall-upload-error" class="err" style="display:none"></p>
      </div>
    </div>
    <input type="hidden" name="photo_url" id="photo_url_field" />

    <p><button class="btn" type="submit">Сохранить</button></p>
  </form>
  </div>
</AdminLayout>

<style>
  .photo-upload__ui { display: none; }
</style>

<script>
  const uploadBtn = document.getElementById('hall-upload-btn');
  const uploadUi = document.getElementById('photo-upload-hall')?.querySelector('.photo-upload__ui') as HTMLElement | null;

  // Reveal the upload UI now that JS is available
  if (uploadUi) uploadUi.style.display = '';

  uploadBtn?.addEventListener('click', async () => {
    const fileInput = document.getElementById('hall-file-input') as HTMLInputElement;
    const errEl = document.getElementById('hall-upload-error') as HTMLElement;
    errEl.style.display = 'none';
    if (!fileInput.files?.[0]) return;
    const fd = new FormData();
    fd.append('file', fileInput.files[0]);
    try {
      const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
      const data = await res.json();
      if (!res.ok || data.error) {
        errEl.textContent = data.error || 'Ошибка загрузки';
        errEl.style.display = '';
        return;
      }
      (document.getElementById('photo_url_field') as HTMLInputElement).value = data.url;
      (document.getElementById('hall-photo-img') as HTMLImageElement).src = data.url;
      (document.getElementById('hall-photo-preview') as HTMLElement).style.display = '';
    } catch {
      errEl.textContent = 'Сеть недоступна';
      errEl.style.display = '';
    }
  });
</script>
