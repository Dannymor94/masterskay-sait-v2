---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { listLeads, updateLeadStatus, LEAD_STATUSES } from '../../server/leads.ts';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  updateLeadStatus(String(form.get('id') ?? ''), String(form.get('status') ?? ''));
  return Astro.redirect('/admin/leads', 303);
}
const leads = listLeads();
const user = Astro.locals.adminUser;
---
<AdminLayout title="Заявки" user={user}>
  <p class="muted" style="margin-bottom:var(--space-2)">
    Просмотр заявок (аренда / визит / событие) и смена статуса.
    Запись во внешние системы (CRM / уведомления) не делается автоматически —
    двухфазно с человеком.
  </p>

  {leads.length === 0 ? (
    <div style="
      padding: var(--space-4) var(--space-3);
      text-align: center;
      background: var(--surface);
      border: 1px dashed var(--border);
      border-radius: var(--radius-md);
      color: var(--text-muted);
    ">
      <p style="font-size:2rem;margin:0 0 0.5rem">◆</p>
      <p style="margin:0;font-size:0.9rem">Заявок пока нет.</p>
    </div>
  ) : (
    <table>
      <thead>
        <tr>
          <th>Дата</th>
          <th>Тип</th>
          <th>Имя</th>
          <th>Контакт</th>
          <th>Зал / детали</th>
          <th>Статус</th>
        </tr>
      </thead>
      <tbody>
        {leads.map((l) => (
          <tr>
            <td class="muted" style="white-space:nowrap;font-size:0.8rem">{l.created_at}</td>
            <td>
              <span class="tag">{l.type}</span>
            </td>
            <td>{l.name}</td>
            <td>{l.contact}</td>
            <td class="muted" style="font-size:0.82rem">{l.source_page}</td>
            <td>
              <form method="POST" class="inline" style="display:flex;align-items:center;gap:0.4rem">
                <input type="hidden" name="id" value={l.id} />
                <select name="status" style="font-size:0.8rem;padding:0.25rem 0.4rem;max-width:8rem">
                  {LEAD_STATUSES.map((st) => (
                    <option value={st} selected={st === l.status}>{st}</option>
                  ))}
                </select>
                <button class="btn btn-secondary btn-sm" type="submit">OK</button>
              </form>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</AdminLayout>
